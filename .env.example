# Azure OpenAI (direct, key-based — chat + embeddings)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_EVAL_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072

# Upstream API keys (one per MCP server domain) — placeholders only, never commit real values.
# Task 1 documents where to obtain each key and its free-tier limits.
NEWSAPI_KEY=            # News / World Data -> NewsAPI.org
OPENWEATHER_API_KEY=    # Weather           -> OpenWeatherMap
FINNHUB_API_KEY=        # Finance           -> Finnhub
YOUTUBE_API_KEY=        # Media             -> YouTube Data API v3

# MCP server ports (each server binds its own localhost port)
WORLD_DATA_PORT=8801
FINANCE_PORT=8802
MEDIA_PORT=8803

# Logging
LOG_LEVEL=INFO          # set to DEBUG for verbose logs